{
  "compilerOptions": {
    "incremental": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "stripInternal": true,
    "noEmit": false,
    "esModuleInterop": true,
    "types": ["jest"],
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "esnext"
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules", "dist", "sample"]
}
